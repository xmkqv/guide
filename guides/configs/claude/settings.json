{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 90,
  "env": {
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_AGENT_TEAMS_DISPLAY": "tmux",
    "ENABLE_TOOL_SEARCH": "auto"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "NotebookEdit",
      "TodoWrite",
      "Bash",
      "Glob",
      "Grep",
      "Task",
      "WebFetch",
      "WebSearch",
      "mcp__plugin_context7_context7",
      "mcp__codex",
      "mcp__serena",
      "mcp__codebase-memory-mcp"
    ],
    "deny": [
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Read(**/docker-compose*.yml)",
      "Write(**/.env*)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf $HOME)",
      "Bash(useradd:*)",
      "Bash(userdel:*)",
      "Bash(usermod:*)",
      "Bash(passwd:*)",
      "Bash(chown:*)",
      "Bash(chmod 777:*)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(doas:*)",
      "Bash(reboot)",
      "Bash(shutdown:*)",
      "Bash(halt:*)",
      "Bash(poweroff:*)",
      "Bash(init:*)",
      "Bash(systemctl:*)",
      "Bash(service:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",
      "Bash(parted:*)",
      "Bash(diskutil:*)",
      "Bash(kill -9 1)",
      "Bash(killall:*)",
      "Bash(nmap:*)",
      "Bash(masscan:*)",
      "Bash(nikto:*)",
      "Bash(sqlmap:*)",
      "Bash(metasploit:*)",
      "Bash(:*coin:*miner:*)",
      "Bash(*git stash*)",
      "Bash(:*cryptominer:*)",
      "Bash(:*xmrig:*)",
      "Read(**/.git/**)",
      "Read(**/dist/**)",
      "Read(**/.next/**)",
      "Read(**/.nuxt/**)",
      "Read(**/coverage/**)",
      "Read(**/__pycache__/**)",
      "Read(**/.pytest_cache/**)",
      "Read(**/venv/**)",
      "Read(**/.venv/**)",
      "Read(**/*.egg-info/**)",
      "Read(**/.cargo/registry/**)",
      "Read(**/target/debug/**)",
      "Read(**/target/release/**)"
    ]
  },
  "enabledMcpjsonServers": [
    "serena",
    "codebase-memory-mcp",
    "postgres",
    "codex"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/m/qxotk/libs/guide/guides/configs/claude/hooks/on-change.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Grep|Glob|Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/cbm-code-discovery-gate"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "impeccable": {
      "source": {
        "source": "github",
        "repo": "pbakaus/impeccable"
      }
    }
  },
  "effortLevel": "high",
  "voiceEnabled": true
}
