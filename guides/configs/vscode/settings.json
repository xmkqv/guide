{
	/*** WINDOW & WORKBENCH ***/
	"window.zoomLevel": 2,
	/*** TERMINAL ***/
	"terminal.integrated.scrollback": 10000,
	"workbench.iconTheme": "material-icon-theme",
	"workbench.secondarySideBar.defaultVisibility": "hidden",
	"workbench.sideBar.location": "right",
	"workbench.activityBar.location": "bottom",
	"workbench.startupEditor": "welcomePage",
	"zenMode.centerLayout": false,
	"extensions.ignoreRecommendations": true,
	"redhat.telemetry.enabled": false,
	"security.workspace.trust.untrustedFiles": "open",
	"task.allowAutomaticTasks": "on",
	/*** EDITOR (GENERAL) ***/
	"editor.fontSize": 14,
	"editor.tabSize": 4,
	"editor.indentSize": "tabSize",
	"editor.lineNumbers": "interval",
	"editor.guides.bracketPairs": true,
	"editor.guides.highlightActiveBracketPair": false,
	"editor.lightbulb.enabled": "off",
	"editor.minimap.enabled": false,
	"editor.glyphMargin": false,
	"editor.accessibilitySupport": "off",
	"editor.autoClosingBrackets": "beforeWhitespace",
	"editor.unicodeHighlight.allowedCharacters": {
		"α": true
	},
	// formatting
	"editor.defaultFormatter": "biomejs.biome",
	"editor.formatOnSave": true,
	"editor.codeActionsOnSave": {
		"source.fixAll.biome": "explicit",
		"source.organizeImports.biome": "explicit",
		"source.addMissingImports": "always",
		"source.removeUnusedImports": "always"
	},
	// BIOME
	"biome.lspBin": "/Users/m/.bun/bin/biome",
	// suggestions
	"editor.suggest.showFiles": false,
	"editor.suggest.showSnippets": true,
	"editor.snippetSuggestions": "inline",
	"editor.suggest.showWords": true,
	"editor.suggest.filterGraceful": true,
	"editor.suggest.localityBonus": true,
	"editor.suggestSelection": "recentlyUsedByPrefix",
	"editor.quickSuggestions": {
		"other": "on",
		"comments": "off",
		"strings": true
	},
	"editor.tabCompletion": "on",
	/*** GIT ***/
	"git.autofetch": true,
	"git.openRepositoryInParentFolders": "never",
	"git.enableSmartCommit": true,
	"git.confirmSync": false,
	"git.ignoreMissingGitWarning": true,
	/*** GITHUB COPILOT ***/
	"chat.commandCenter.enabled": false,
	"github.copilot.editor.enableCodeActions": false,
	"github.copilot.chat.useProjectTemplates": false,
	"github.copilot.chat.terminalChatLocation": "terminal",
	"github.copilot.nextEditSuggestions.enabled": true,
	"github.copilot.enable": {
		"*": true,
		"markdown": true
	},
	/*** MATERIAL ICON THEME ***/
	"material-icon-theme.folders.associations": {
		"qs": "Unity",
		"xs": "Unity",
		"qx": "Unity",
		"files": "Other",
		"node": "Cluster",
		"tileEl": "Windows",
		"link": "Unity",
		"flux": "Mercurial"
	},
	"material-icon-theme.activeIconPack": "none",
	/*** FILES & SEARCH ***/
	"files.exclude": {
		"**/__pycache__": true,
		"**/.pytest_cache": true,
		"**/*.egg-info": true,
		"**/.serena": true
	},
	"files.watcherExclude": {
		"**/node_modules/**": true,
		"**/dist/**": true,
		"**/.git/**": true,
		"**/build/**": true,
		"**/Library/Containers/**": true,
		"**/Library/Group Containers/**": true
	},
	"search.exclude": {
		"**/node_modules/**": true,
		"**/dist/**": true,
		"**/build/**": true,
		"**/.git/**": true,
		"**/*.egg-info": true,
		"**/__pycache__": true,
		"**/.python-version": true,
		"**/.ruff_cache": true,
		"**/.pytest_cache": true,
		"**/.coverage": true,
		"**/.DS_Store": true
	},
	"files.associations": {
		"*.sql": "postgres",
		".env": "dotenv",
		".env.*": "dotenv",
		".svg": "svg",
		"*.css": "css",
		"settings.json": "jsonc",
		"Justfile": "just",
		"justfile": "just",
		"*.just": "just"
	},
	"search.useIgnoreFiles": true,
	/*** LANGUAGE-SPECIFIC SETTINGS ***/
	/* markdown */
	"markdownlint.configFile": "/Users/m/qxotk/libs/guide/guides/configs/.markdownlint.json",
	"markdown.validate.referenceLinks.enabled": "ignore",
	"markdown.preview.scrollPreviewWithEditor": false,
	"markdown.preview.scrollEditorWithPreview": false,
	"markdown.validate.enabled": true,
	"[markdown]": {
		"editor.unicodeHighlight.ambiguousCharacters": false,
		"editor.unicodeHighlight.invisibleCharacters": false,
		"diffEditor.ignoreTrimWhitespace": false,
		"editor.wordWrap": "off",
		"editor.autoClosingBrackets": "never",
		"editor.autoSurround": "never",
		"files.trimTrailingWhitespace": true,
		"editor.codeActionsOnSave": {
			"source.fixAll.markdownlint": "explicit"
		},
		"editor.defaultFormatter": "darkriszty.markdown-table-prettify"
	},
	/* postgresql */
	"[postgres]": {
		"editor.defaultFormatter": "bradymholt.pgformatter",
		"editor.tabSize": 2
	},
	"pgFormatter.spaces": 2,
	"pgFormatter.maxLineLength": 80,
	"pgFormatter.commaEnd": false,
	"pgFormatter.noComment": false,
	"pgFormatter.formatType": true,
	"pgFormatter.keywordCase": 1,
	/* typescript/javascript */
	"typescript.preferences.importModuleSpecifier": "shortest",
	"typescript.tsserver.log": "off",
	"typescript.tsserver.maxTsServerMemory": 3072,
	"typescript.updateImportsOnFileMove.enabled": "always",
	"typescript.suggest.autoImports": true,
	"typescript.suggest.paths": true,
	"typescript.preferences.autoImportFileExcludePatterns": [
		"**/dist/**",
		"**/.dev/**",
		"**/.demos/**",
		"**/build/**",
		"**/coverage/**"
	],
	"typescript.preferences.autoImportSpecifierExcludeRegexes": [
		"^node:inspector",
		"^fs",
		"fs/promises",
		"^node:",
		"^typescript",
		"^assert",
		"^console"
	],
	/* python */
	"[python]": {
		"editor.defaultFormatter": "charliermarsh.ruff",
		"editor.codeActionsOnSave": {
			"source.fixAll": "always",
			"source.unusedImports": "always",
			"source.organizeImports": "always"
		}
	},
	"python.languageServer": "Pylance",
	"python.analysis.autoImportCompletions": true,
	"python.analysis.indexing": true,
	"python.terminal.executeInFileDir": true,
	"notebook.markup.fontSize": 13,
	"notebook.outline.showCodeCells": true,
	"notebook.output.fontSize": 12,
	"notebook.cellToolbarLocation": {
		"default": "left"
	},
	"notebook.cellToolbarVisibility": "hover",
	"notebook.output.scrolling": true,
	/* css */
	"[css]": {
		"editor.codeActionsOnSave": {
			"source.fixAll.stylelint": "explicit",
			"source.action.useSortedProperties.biome": "explicit"
		}
	},
	"cssvar.enableHover": true,
	"css.validate": false,
	"less.validate": false,
	"scss.validate": false,
	"stylelint.validate": [
		"css"
	],
	/* json/jsonc */
	"[json]": {
		"editor.defaultFormatter": "vscode.json-language-features"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "vscode.json-language-features"
	},
	/* shell script */
	"[shellscript]": {
		"editor.defaultFormatter": "foxundermoon.shell-format"
	},
	"shellformat.flag": "-i 2 -ci -bn -sr",
	"shellformat.effectLanguages": [
		"shellscript",
		"dockerfile",
		"dotenv",
		"hosts",
		"jvmoptions",
		"ignore",
		"gitignore",
		"properties",
		"spring-boot-properties",
		"azcli",
		"bats"
	],
	/* yaml */
	"yaml.format.enable": false,
	/* docker compose */
	"[dockercompose]": {
		"editor.insertSpaces": true,
		"editor.tabSize": 2,
		"editor.autoIndent": "advanced",
		"editor.defaultFormatter": "redhat.vscode-yaml"
	},
	/* github actions */
	"[github-actions-workflow]": {
		"editor.defaultFormatter": "redhat.vscode-yaml"
	},
	"json.schemaDownload.trustedDomains": {
		"https://schemastore.azurewebsites.net/": true,
		"https://raw.githubusercontent.com/": true,
		"https://www.schemastore.org/": true,
		"https://json.schemastore.org/": true,
		"https://json-schema.org/": true,
		"https://biomejs.dev": true
	},
	"github.copilot.chat.agent.currentEditorContext.enabled": false,
	"github.copilot.chat.languageContext.typescript.items": "minimal",
	"github.copilot.chat.newWorkspaceCreation.enabled": false,
	"github.copilot.chat.organizationCustomAgents.enabled": false,
	"github.copilot.chat.organizationInstructions.enabled": false,
	"github.copilot.chat.responsesApiReasoningEffort": "low",
	"github.copilot.chat.reviewAgent.enabled": false,
	"github.copilot.chat.reviewSelection.enabled": false,
	/*** MARKDOWN ITALIC OVERRIDE ***/
	"editor.tokenColorCustomizations": {
		"textMateRules": [
			{
				"scope": [
					"markup.italic.markdown",
					"punctuation.definition.italic.markdown"
				],
				"settings": {
					"fontStyle": "",
					"foreground": "#CCCCCC"
				}
			}
		]
	}
}